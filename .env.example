# MySQL DSN — same database as SIMRS Khanza
#
# Docker app → MySQL on host:
DATABASE_DSN=user:password@tcp(host.docker.internal:3306)/sik?parseTime=true&loc=Local&charset=utf8mb4
#
# ./scripts/run-local.sh (bundled MariaDB) — optional override; default is set in docker-compose.local.yml:
# DATABASE_DSN=mapper:mapper@tcp(mysql:3306)/sik?parseTime=true&loc=Local&charset=utf8mb4

AUTH_USERNAME=admin
AUTH_PASSWORD=change-me

APP_LISTEN=:8080
APP_PORT=8080
APP_ENV=development

# Only used with docker-compose.local.yml
MYSQL_PORT=3307
